{
	"$schema": "https://biomejs.dev/schemas/2.4.11/schema.json",
	"name": "kapy-monorepo",
	"private": true,
	"type": "module",
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"dev": "bun run --filter './packages/*' dev",
		"build": "bun run --cwd packages/kapy-components build && bun run --cwd packages/kapy build",
		"test": "bun test packages/kapy/test/index.test.ts packages/kapy/test/integration/",
		"test:all": "bun test packages/kapy/test/",
		"lint": "biome check .",
		"typecheck": "tsc --noEmit",
		"check": "biome check . && tsc --noEmit && bun test packages/kapy/test/",
		"version:bump": "bun scripts/bump-version.ts",
		"release": "bun scripts/release.ts",
		"prepare": "husky",
		"tui": "bun run --cwd packages/kapy src/cli.ts"
	},
	"devDependencies": {
		"typescript": "^6.0.2",
		"@biomejs/biome": "^2.4.12",
		"husky": "^9.1.7"
	}
}