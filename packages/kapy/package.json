{
	"name": "kapy",
	"version": "0.1.0",
	"type": "module",
	"description": "The pi.dev for CLI — extensible CLI framework with extensions, hooks, middleware, and TUI",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"bin": {
		"kapy": "./dist/cli.js"
	},
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		},
		"./middleware": {
			"import": "./dist/middleware/index.js",
			"types": "./dist/middleware/index.d.ts"
		},
		"./middleware/logging": {
			"import": "./dist/middleware/logging.js",
			"types": "./dist/middleware/logging.d.ts"
		},
		"./middleware/timing": {
			"import": "./dist/middleware/timing.js",
			"types": "./dist/middleware/timing.d.ts"
		},
		"./middleware/error-handler": {
			"import": "./dist/middleware/error-handler.js",
			"types": "./dist/middleware/error-handler.d.ts"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"dev": "bun run --watch src/cli.ts",
		"build": "bun build src/index.ts src/cli.ts --outdir dist --target bun",
		"test": "bun test",
		"lint": "biome check src/",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@opentui/core": "^0.1.97",
		"kapy-components": "workspace:*",
		"picocolors": "^1.1.0"
	},
	"devDependencies": {
		"typescript": "^5.7.0",
		"@types/bun": "^1.2.0"
	},
	"keywords": [
		"cli",
		"framework",
		"extensible",
		"extensions",
		"tui",
		"opentui"
	],
	"license": "MIT"
}
