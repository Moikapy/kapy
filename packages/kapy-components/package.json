{
	"name": "@moikapy/kapy-components",
	"version": "0.1.1",
	"type": "module",
	"description": "UI components for kapy TUI — built on @opentui/core",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/Moikapy/kapy"
	},
	"homepage": "https://github.com/Moikapy/kapy#readme",
	"author": "Moikapy",
	"files": [
		"dist"
	],
	"scripts": {
		"dev": "bun run --watch src/index.ts",
		"build": "bun build src/index.ts --outdir dist --target bun && tsc --emitDeclarationOnly --outDir dist",
		"test": "bun test",
		"lint": "biome check src/",
		"typecheck": "tsc --noEmit",
		"prepublishOnly": "bun run build"
	},
	"dependencies": {
		"@opentui/core": "^0.1.97"
	},
	"devDependencies": {
		"typescript": "^5.7.0",
		"@types/bun": "^1.2.0"
	},
	"keywords": [
		"tui",
		"components",
		"opentui",
		"cli"
	],
	"license": "MIT"
}
