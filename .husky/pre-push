#!/usr/bin/env bash
# kapy pre-push hook — ensure version consistency before pushes
set -e

# Only check version consistency on main branch pushes
BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "unknown")

if [ "$BRANCH" = "main" ]; then
  echo "🐹 Checking version consistency on main..."

  ROOT_VERSION=$(node -p "require('./package.json').version" 2>/dev/null || echo "0.0.0")
  KAPY_VERSION=$(node -p "require('./packages/kapy/package.json').version" 2>/dev/null || echo "0.0.0")
  COMPONENTS_VERSION=$(node -p "require('./packages/kapy-components/package.json').version" 2>/dev/null || echo "0.0.0")
  CREATE_VERSION=$(node -p "require('./packages/create-kapy/package.json').version" 2>/dev/null || echo "0.0.0")

  if [ "$KAPY_VERSION" != "$ROOT_VERSION" ] || [ "$COMPONENTS_VERSION" != "$ROOT_VERSION" ] || [ "$CREATE_VERSION" != "$ROOT_VERSION" ]; then
    echo "⚠️  Version mismatch detected:"
    echo "   root: $ROOT_VERSION"
    echo "   kapy: $KAPY_VERSION"
    echo "   kapy-components: $COMPONENTS_VERSION"
    echo "   create-kapy: $CREATE_VERSION"
    echo ""
    echo "Run: bun run version:bump <major|minor|patch>"
    exit 1
  fi
fi

echo "✅ Pre-push checks passed"