#!/usr/bin/env bash
# kapy pre-commit hook — lint, typecheck, test
set -e

echo "🐹 Running pre-commit checks..."

echo "→ Biome lint..."
biome check . 2>&1

echo "→ TypeScript check..."
bun run typecheck 2>&1

echo "→ Running unit tests..."
bun test packages/kapy/test/unit/ packages/kapy/test/index.test.ts 2>&1

echo "✅ All checks passed!"